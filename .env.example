# Granville WordPress REST (booking, gift card, blog).
# If unset, requests use https://cms.granvilletattoo.ca/index.php?rest_route=/granville/v1/...
# (pretty /wp-json/... is broken on that host; see src/lib/granvilleFetchUrl.ts).
#
# Override examples:
# - Pretty root (no trailing slash): https://example.com/wp-json/granville/v1
# - Query form entry: https://example.com/index.php
NEXT_PUBLIC_BOOKING_API_BASE=

# Optional: server-only override for /api/granville proxy + SSR blog (same rules as above).
# BOOKING_API_BASE_URL=

# reCAPTCHA v3 (booking + gift card). Required for those forms in production.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Only if the site is served from a subpath (uncommon on Vercel root domain).
# NEXT_PUBLIC_BASE_PATH=
